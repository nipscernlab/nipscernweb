name = "nipscern-hearts"
main = "src/index.js"
compatibility_date = "2025-01-01"

# D1 database binding. After `wrangler d1 create nipscern-hearts`, paste the
# printed database_id below.
[[d1_databases]]
binding = "DB"
database_name = "nipscern-hearts"
database_id = "REPLACE_WITH_YOUR_D1_DATABASE_ID"

# Once you want it on the site's own domain (no CORS), add a route on the zone:
# [[routes]]
# pattern = "www.nipscern.com/api/hearts*"
# zone_name = "nipscern.com"
#
# The SALT is a secret, not stored here. Set it with:
#   wrangler secret put SALT
